    name   = "UpTrend",
    color  = "#00C853",   # green
    width  = 2,
    style  = "line"
)

# Red resistance line (down-trend)
indicator.plot(
    dn_line,
    name   = "DownTrend",
    color  = "#D50000",   # red
    width  = 2,
    style  = "line"
)

# Buy / Sell markers
if SHOW_SIGNALS:
    buy_prices  = np.where(buy_signal,  up, np.nan)
    sell_prices = np.where(sell_signal, dn, np.nan)

    indicator.plot_marker(
        buy_prices,
        name      = "Buy",
        color     = "#00C853",
