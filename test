        text      = "Sell",
        text_color= "#FFFFFF"
    )

# Background highlighting
if HIGHLIGHTING:
    bg = np.where(trend ==  1,  1.0,    # uptrend   → green tint
         np.where(trend == -1, -1.0,    # downtrend → red tint
         np.nan))
