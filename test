import numpy as np

# ── PARAMETERS (edit these to match your preferences) ──────────────────────

ATR_PERIOD     = 10       # ATR Period
MULTIPLIER     = 3.0      # ATR Multiplier
USE_RMA_ATR    = True     # True = RMA/Wilder ATR (like changeATR=true in Pine)
# False = SMA-based ATR  (like changeATR=false)
SHOW_SIGNALS   = True     # Show Buy/Sell labels
HIGHLIGHTING   = True     # Fill trend background

# ── HELPER: RMA (Wilder’s Moving Average) ──────────────────────────────────

def rma(series, period):
result = np.full(len(series), np.nan)
alpha  = 1.0 / period
# Seed with SMA of first `period` values
seed_slice = series[:period]
valid      = seed_slice[~np.isnan(seed_slice)]
if len(valid) < period:
return result
result[period - 1] = np.mean(valid)
for i in range(period, len(series)):
if not np.isnan(series[i]):
result[i] = alpha * series[i] + (1 - alpha) * result[i - 1]
else:
result[i] = result[i - 1]
return result

# ── HELPER: SMA ────────────────────────────────────────────────────────────

def sma(series, period):
result = np.full(len(series), np.nan)
for i in range(period - 1, len(series)):
window = series[i - period + 1 : i + 1]
if not np.any(np.isnan(window)):
result[i] = np.mean(window)
return result

